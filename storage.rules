rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Permitir que cualquiera vea las imágenes (necesario para el portfolio público)
      allow read: if true;
      // Solo permitir subir/borrar si el usuario está autenticado (el administrador)
      allow write: if request.auth != null;
    }
  }
}
